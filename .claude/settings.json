{
  "permissions": {
    "allow": [
      "Read(~/obsidian_notes/**)",
      "Write(~/obsidian_notes/**)",
      "Edit(~/obsidian_notes/**)",
      "mcp__vault-mcp__vault_find",
      "mcp__vault-mcp__vault_project",
      "mcp__vault-mcp__vault_show",
      "mcp__vault-mcp__vault_links"
    ],
    "additionalDirectories": [
      "~/obsidian_notes"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/agent-configs/hooks/session-start.sh",
            "timeout": 10,
            "statusMessage": "Loading vault context..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/agent-configs/hooks/pre-compact.sh",
            "timeout": 10,
            "statusMessage": "Checking vault state before compression..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/agent-configs/hooks/session-stop.sh",
            "timeout": 5,
            "statusMessage": "Session end check..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/agent-configs/hooks/validate-vault-write.sh",
            "timeout": 5,
            "statusMessage": "Validating vault write..."
          },
          {
            "type": "command",
            "command": "bash ~/agent-configs/hooks/detect-stale-notes.sh",
            "timeout": 5,
            "statusMessage": "Checking for stale vault notes..."
          },
          {
            "type": "command",
            "command": "bash ~/agent-configs/hooks/update-timeline.sh",
            "timeout": 5,
            "statusMessage": "Updating timeline..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/agent-configs/hooks/validate-vault-write.sh",
            "timeout": 5,
            "statusMessage": "Validating vault write..."
          },
          {
            "type": "command",
            "command": "bash ~/agent-configs/hooks/detect-stale-notes.sh",
            "timeout": 5,
            "statusMessage": "Checking for stale vault notes..."
          },
          {
            "type": "command",
            "command": "bash ~/agent-configs/hooks/update-timeline.sh",
            "timeout": 5,
            "statusMessage": "Updating timeline..."
          }
        ]
      }
    ]
  },
  "advisorModel": "opus",
  "mcpServers": {
    "vault-mcp": {
      "command": "bash",
      "args": [
        "-c",
        "python3 \"$HOME/agent-configs/bin/vault-mcp.py\""
      ]
    }
  },
  "trustedDirectories": [
    "~/obsidian_notes"
  ],
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ide": {
    "hasSeenNudge": true,
    "enabled": true
  }
}
