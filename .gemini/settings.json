{
  "model": {
    "compressionThreshold": 0.8
  },
  "contextManagement": {
    "historyWindow": {
      "maxTokens": 500000,
      "retainedTokens": 60000
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/agent-configs/hooks/session-start.sh",
            "timeout": 10000,
            "statusMessage": "Loading vault context..."
          }
        ]
      }
    ],
    "PreCompress": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/agent-configs/hooks/pre-compact.sh",
            "timeout": 10000,
            "statusMessage": "Checking vault state before compression..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/agent-configs/hooks/session-stop.sh",
            "timeout": 5000,
            "statusMessage": "Session end check..."
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "write_file",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/agent-configs/hooks/validate-vault-write.sh",
            "timeout": 5000,
            "statusMessage": "Validating vault write..."
          },
          {
            "type": "command",
            "command": "$HOME/agent-configs/hooks/detect-stale-notes.sh",
            "timeout": 5000,
            "statusMessage": "Checking for stale vault notes..."
          },
          {
            "type": "command",
            "command": "$HOME/agent-configs/hooks/update-timeline.sh",
            "timeout": 5000,
            "statusMessage": "Updating timeline..."
          }
        ]
      },
      {
        "matcher": "replace",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/agent-configs/hooks/validate-vault-write.sh",
            "timeout": 5000,
            "statusMessage": "Validating vault write..."
          },
          {
            "type": "command",
            "command": "$HOME/agent-configs/hooks/detect-stale-notes.sh",
            "timeout": 5000,
            "statusMessage": "Checking for stale vault notes..."
          },
          {
            "type": "command",
            "command": "$HOME/agent-configs/hooks/update-timeline.sh",
            "timeout": 5000,
            "statusMessage": "Updating timeline..."
          }
        ]
      }
    ]
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ide": {
    "hasSeenNudge": true,
    "enabled": true
  }
}
